<!DOCTYPE html>
<html>
  <body style="margin:0; padding:30px 20px; background:#f6f1eb; font-family:Arial, sans-serif;">

    <div style="max-width:560px; margin:0 auto; background:#fffdf9; border-radius:16px; overflow:hidden; border:1px solid #e0d5c8;">

      <!-- Header — compact -->
      <div style="background:#c4622d; padding:16px 24px;">
        <table cellpadding="0" cellspacing="0" border="0" width="100%">
          <tr>
            <td style="vertical-align:middle;">
              <table cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="vertical-align:middle; padding-right:10px;">
                    <div style="width:34px; height:34px; background:rgba(255,255,255,0.18); border-radius:8px; text-align:center; line-height:34px; font-size:18px;">🪡</div>
                  </td>
                  <td style="vertical-align:middle;">
                    <p style="margin:0; color:#fff; font-size:15px; font-weight:bold;">Handmade Marketplace</p>
                  </td>
                </tr>
              </table>
            </td>
            <td align="right" style="vertical-align:middle;">
              <p style="margin:0; color:rgba(255,255,255,0.5); font-size:11px;">Verification Email</p>
            </td>
          </tr>
        </table>
      </div>

      <!-- Decorative strip -->
      <div style="height:3px; background:linear-gradient(90deg, #c4622d 0%, #e8956a 40%, #f5c4a0 70%, #fde8d8 100%);"></div>

      <!-- Body -->
      <div style="padding:32px 28px;">

        <p style="margin:0 0 6px; font-size:20px; font-weight:bold; color:#3b2c24;">Hello, <%= name %> 👋</p>
        <p style="margin:0 0 24px; font-size:14px; color:#7a6555; line-height:1.7;">
          Welcome to the Handmade community! Use the verification code below to confirm your email and start exploring handcrafted treasures from talented artisans.
        </p>

        <!-- OTP Card -->
        <div style="background:#fdf6f0; border:1px solid #e8c9b0; border-radius:14px; padding:24px 20px; text-align:center; margin-bottom:20px;">
          <p style="margin:0 0 14px; font-size:11px; font-weight:bold; color:#a07858; letter-spacing:1.5px; text-transform:uppercase;">Your verification code</p>

          <table cellspacing="8" cellpadding="0" border="0" style="margin:0 auto 14px;">
            <tr>
              <% otp.split('').forEach(function(digit) { %>
              <td style="width:44px; height:52px; background:#fff; border:1px solid #ddc8b4; border-radius:10px; text-align:center; vertical-align:middle; font-size:24px; font-weight:bold; color:#c4622d; font-family:Georgia,serif;">
                <%= digit %>
              </td>
              <% }) %>
            </tr>
          </table>

          <div style="display:inline-block; background:#fdeee6; border-radius:20px; padding:5px 14px;">
            <span style="font-size:12px; color:#a05030;">⏱ Expires in <b>10 minutes</b></span>
          </div>
        </div>

        <!-- Info boxes -->
        <table width="100%" cellspacing="10" cellpadding="0" border="0" style="margin-bottom:24px;">
          <tr>
            <td style="background:#f9f5f1; border-radius:10px; padding:12px 14px; width:50%; vertical-align:top;">
              <p style="margin:0 0 3px; font-size:13px; font-weight:bold; color:#3b2c24;">🛡 Secure code</p>
              <p style="margin:0; font-size:12px; color:#7a6555; line-height:1.5;">Never share this with anyone</p>
            </td>
            <td style="background:#f9f5f1; border-radius:10px; padding:12px 14px; width:50%; vertical-align:top;">
              <p style="margin:0 0 3px; font-size:13px; font-weight:bold; color:#3b2c24;">📱 One-time use</p>
              <p style="margin:0; font-size:12px; color:#7a6555; line-height:1.5;">Valid for a single session only</p>
            </td>
          </tr>
        </table>

        <div style="border-top:1px solid #edddd0; margin-bottom:16px;"></div>

        <p style="margin:0; font-size:12px; color:#9a8778; line-height:1.6;">
          ℹ️ If you didn't create an account with Handmade Marketplace, you can safely ignore this email.
        </p>

      </div>

      <!-- Footer -->
      <div style="background:#f9f3ee; padding:14px 28px; border-top:1px solid #edddd0;">
        <table width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td style="font-size:11px; color:#b09080;">Made with love in Egypt 🇪🇬</td>
            <td align="right" style="font-size:11px; color:#b09080;">
              Unsubscribe &nbsp;·&nbsp; Privacy &nbsp;·&nbsp; Help
            </td>
          </tr>
        </table>
      </div>

    </div>

  </body>
</html>
